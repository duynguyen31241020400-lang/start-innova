# Copy to .env locally if you use tooling that reads it; Vercel sets these in the dashboard.
# Frontend build (npm run build → frontend-config.js)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional: same values as above if you already use Next-style names on Vercel
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Leave empty on Vercel so the browser calls /api on the same origin
FRONTEND_API_BASE_URL=

# API (serverless /api and local backend)
SUPABASE_SERVICE_ROLE_KEY=

# Local Express only (comma-separated origins), optional on Vercel same-origin
CORS_ORIGIN=
